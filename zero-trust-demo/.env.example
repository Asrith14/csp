# Zero-Trust Demo Environment Variables
# Copy this file to .env and customize as needed

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Vault
VAULT_DEV_ROOT_TOKEN_ID=root-token-zero-trust

# Kong Database
KONG_PG_PASSWORD=kong_secret_2024

# Keycloak Database
KEYCLOAK_DB_PASSWORD=keycloak_secret_2024

# Application Database
APP_DB_PASSWORD=app_secret

# Grafana
GF_SECURITY_ADMIN_PASSWORD=admin

# Service Secrets (for production, use Vault)
AUTH_SERVICE_SECRET=auth-service-secret-2024
BACKEND_SERVICE_SECRET=backend-service-secret-2024
API_GATEWAY_SECRET=api-gateway-secret-2024
