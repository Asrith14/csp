# Zero-Trust Demo — Environment Variables
# Copy this file to .env and fill in strong, unique values.
# .env is gitignored and must NEVER be committed.
#
# Generate strong passwords: openssl rand -base64 32

# ---- Keycloak / Postgres (Keycloak) ----
POSTGRES_KEYCLOAK_PASSWORD=change-me-keycloak-db

# ---- Keycloak Admin ----
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin

# ---- Kong / Postgres (Kong) ----
POSTGRES_KONG_PASSWORD=change-me-kong-db

# ---- App Postgres ----
POSTGRES_APP_PASSWORD=change-me-app-db

# ---- HashiCorp Vault (dev mode only — use proper unseal in production) ----
VAULT_DEV_ROOT_TOKEN=change-me-vault-root-token

# ---- Step CA (mTLS certificate authority) ----
STEP_CA_PASSWORD=change-me-step-ca

# ---- Grafana Admin ----
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-admin
